        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.output || '';\n\nlet analysis;\ntry {\n  const clean = raw.replace(/```json|```/g, '').trim();\n  const m = clean.match(/\\{[\\s\\S]*\\}/);\n  analysis = JSON.parse(m ? m[0] : clean);\n} catch(e) {\n  analysis = {\n    tone: 'Could not parse scraped content.',\n    formality: 'unknown',\n    voice_rules: { do: [], dont: [] },\n    top_posts: [],\n    content_patterns: [],\n    posting_style: ''\n  };\n}\n\nreturn {\n  brand_id:      $('SET Normalize Input').item.json.brand_id,\n  channel:       $('SET Normalize Input').item.json.channel_name,\n  handle:        $('SET Normalize Input').item.json.channel_handle,\n  url:           $('SET Normalize Input').item.json.channel_url,\n  analysis_json: JSON.stringify(analysis),\n  updated_at:    new Date().toISOString()\n};"
      },
