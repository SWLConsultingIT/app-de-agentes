      "main": [
        [
          { "node": "Build Config Name", "type": "main", "index": 0 }
        ]
      ]
    },
    "Build Config Name": {
      "main": [
        [
          { "node": "Trigger Social Media Pipeline", "type": "main", "index": 0 }
        ]
      ]
    },
    "Trigger Social Media Pipeline": {
      "main": [
        [
          { "node": "Respond — Pipeline Started", "type": "main", "index": 0 },
          { "node": "Wait 3 minutes", "type": "main", "index": 0 }
        ]
      ]
    },
    "Wait 3 minutes": {
      "main": [
        [
          { "node": "Fetch Analyzed Videos", "type": "main", "index": 0 }
        ]
      ]
    },
    "Fetch Analyzed Videos": {
      "main": [
        [
          { "node": "Extract and Classify Hooks", "type": "main", "index": 0 }
        ]
      ]
    },
    "Extract and Classify Hooks": {
      "main": [
        [
          { "node": "Save Hooks to Supabase", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "notes": "SETUP: Create n8n variables SUPABASE_URL, SUPABASE_ANON, SOCIAL_MEDIA_APP_URL (http://localhost:3000). This workflow: (1) receives hook mining trigger from app.js, (2) gets brand profile from Supabase, (3) triggers social media pipeline to scrape+analyze competitor Instagram videos, (4) waits 3 min then fetches results, (5) extracts+classifies hooks, (6) stores in Supabase content_insights for WF06 to use."
  }
}
