      "id": "167207ec-cfe8-4d5f-bcdc-c4533330696a",
      "name": "HTTP Download Video"
    },
    {
      "parameters": {
        "jsCode": "// Reads binary metadata only — mimeType is stored in binary descriptor, not filesystem-v2 content\nconst binary = $input.first().binary;\nconst videoData = binary && binary.videoData;\nif (!videoData) throw new Error('No binary from HTTP Download Video');\n\nconst mimeType = (videoData.mimeType || 'video/mp4').split(';')[0].trim();\nconst vid = $input.first().json;\n\nreturn [{\n  json: {\n    mime_type: mimeType,\n    link: vid.link,\n    video_url: vid.video_url,\n    thumbnail: vid.thumbnail,\n    creator: vid.creator,\n    views: vid.views,\n    likes: vid.likes,\n    comments: vid.comments,\n    date_posted: vid.date_posted\n  },\n  binary: { videoData: videoData }\n}];"
      },
      "type": "n8n-nodes-base.code",
