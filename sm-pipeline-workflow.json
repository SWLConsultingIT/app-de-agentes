    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst vid = $('SET Extract Analysis').first().json;\nconst conceptsText = (item.content && item.content[0] && item.content[0].text) ? item.content[0].text : '';\n\nreturn [{\n  json: {\n    link: vid.link,\n    thumbnail: vid.thumbnail,\n    creator: vid.creator,\n    views: vid.views || 0,\n    likes: vid.likes || 0,\n    comments: vid.comments || 0,\n    analysis: vid.analysis || '',\n    new_concepts: conceptsText,\n    date_posted: vid.date_posted || '',\n    date_added: new Date().toISOString().split('T')[0],\n    config_name: $('SET Config Context').first().json.config_name,\n    starred: false\n  }\n}];"
      },
