      "name": "SET Extract Analysis"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key",         "value": "={{ $('SET API Keys').first().json.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type",      "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({ model: 'claude-sonnet-4-6', max_tokens: 2048, messages: [{ role: 'user', content: $('SET Config Context').first().json.new_concepts_instruction + '\\n\\n=== REFERENCE VIDEO ===\\nCreator: @' + $json.creator + '\\nViews: ' + $json.views + '\\nLikes: ' + $json.likes + '\\nPosted: ' + $json.date_posted + '\\nLink: ' + $json.link + ($json.analysis && $json.analysis.trim() ? '\\n\\nGemini video analysis:\\n' + $json.analysis : '\\n\\n[Video analysis unavailable — base the concepts on the brand context, target audience, and the creator\\'s engagement metrics above]') }] }) }}",
        "options": {}
