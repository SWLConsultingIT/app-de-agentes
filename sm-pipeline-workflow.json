      "id": "b681489e-56e4-4c85-9def-f28278f7900c",
      "name": "HTTP Apify Dataset"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst nDays = $('SET Config Context').first().json.n_days || 30;\nconst topK = $('SET Config Context').first().json.top_k || 3;\nconst creator = $('SPLIT Creators Loop').first().json.username;\n\nconst cutoff = new Date();\ncutoff.setDate(cutoff.getDate() - nDays);\n\nconst filtered = items\n  .map(i => i.json)\n  .filter(v => {\n    if (!v || (!v.videoUrl && !v.url)) return false;\n    const posted = v.timestamp ? new Date(v.timestamp) : null;\n    return !posted || posted >= cutoff;\n  })\n  .sort((a, b) => (b.videoPlayCount || 0) - (a.videoPlayCount || 0))\n  .slice(0, topK)\n  .map(v => ({\n    link: v.url || (v.shortCode ? ('https://www.instagram.com/reel/' + v.shortCode + '/') : v.videoUrl),\n    video_url: v.videoUrl || '',\n    thumbnail: v.displayUrl || v.thumbnailUrl || '',\n    creator: creator,\n    views: v.videoPlayCount || 0,\n    likes: v.likesCount || 0,\n    comments: v.commentsCount || 0,\n    date_posted: v.timestamp ? new Date(v.timestamp).toISOString().split('T')[0] : ''\n  }));\n\n// Return a skip marker when no videos so the creator loop can advance\nif (!filtered.length) return [{ json: { _no_videos: true } }];\nreturn filtered.map(v => ({ json: v }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [16032, -1264],
